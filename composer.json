{
    "name": "hertzogjr/fipe-php-sdk",
    "description": "An unofficial fipe api sdk.",
    "type": "library",
    "require": {
        "php": "^8.4",
        "ext-openssl": "*",
        "guzzlehttp/guzzle": "^7.10"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "symfony/var-dumper": "^8.0",
        "pestphp/pest": "^4.4"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Hertzogjr\\FipePhpSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Junior Hertzog",
            "email": "hertzogjr16@gmail.com"
        }
    ],
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "format": "./vendor/bin/pint",
        "test": "./vendor/bin/pest"
    }
}
